@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="card">
            <div class="card-body text-center">
                <div style="width:56px;height:56px;background:#dcfce7;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#16a34a" viewBox="0 0 16 16">
                        <path d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.02.02 0 0 0 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3zM15 6.437l-6.324 3.05a1.5 1.5 0 0 1-1.352 0L1 6.437V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5z"/>
                    </svg>
                </div>
                @if (Model.ResetUrl != null)
                {
                    <h3 class="fw-bold mb-2">Reset Your Password</h3>
                    <p class="text-muted mb-4">This app doesn't have a real email sender configured, so use the link below directly.</p>
                    <a href="@Model.ResetUrl" class="btn btn-primary w-100 py-2 fw-semibold mb-2">Reset My Password</a>
                    <a asp-page="./Login" class="btn btn-outline-secondary w-100 py-2 fw-semibold">Back to Log in</a>
                }
                else
                {
                    <h3 class="fw-bold mb-2">Check your inbox</h3>
                    <p class="text-muted mb-4">If an account exists for that email, a reset link has been sent.</p>
                    <a asp-page="./Login" class="btn btn-outline-secondary w-100 py-2 fw-semibold">Back to Log in</a>
                }
            </div>
        </div>
    </div>
</div>
