@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-1">Change Password</h5>
        <p class="text-muted mb-4" style="font-size:.9rem;">Choose a strong password to keep your account secure.</p>

        <form id="change-password-form" method="post" style="max-width:480px;">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Current password" />
                <label asp-for="Input.OldPassword">Current Password</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="New password" />
                <label asp-for="Input.NewPassword">New Password</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
            </div>
            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" />
                <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary btn-lg px-5">Update Password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
