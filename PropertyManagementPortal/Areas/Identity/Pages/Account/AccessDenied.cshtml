@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="card">
            <div class="card-body text-center">
                <div style="width:56px;height:56px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#dc2626" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.964 0L.165 13.233c-.457.778.091 1.767.982 1.767h13.706c.89 0 1.438-.99.982-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                    </svg>
                </div>
                <h3 class="fw-bold mb-2 text-danger">Access Denied</h3>
                <p class="text-muted mb-4">You do not have permission to access this resource.</p>
                <a asp-controller="Home" asp-action="Index" asp-area="" class="btn btn-outline-secondary w-100 py-2 fw-semibold">Back to Home</a>
            </div>
        </div>
    </div>
</div>
