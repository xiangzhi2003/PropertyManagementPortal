@{
    ViewData["Title"] = "Dashboard";
    var user = ViewBag.User as PropertyManagementPortal.Models.ApplicationUser;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <div style="width:52px;height:52px;background:#fef3c7;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:#d97706;flex-shrink:0;">
        @(user?.FullName?.FirstOrDefault() ?? '?')
    </div>
    <div>
        <h4 class="fw-bold mb-0">Welcome, @user?.FullName</h4>
        <span class="badge" style="background:#fef3c7;color:#92400e;">Maintenance Staff</span>
    </div>
</div>

<div class="card">
    <div class="card-body p-4 text-center py-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#9ca3af" viewBox="0 0 16 16" class="mb-3">
            <path d="M1 0 0 1l2.2 3.081a1 1 0 0 0 .815.419h.07a1 1 0 0 1 .708.293l2.675 2.675-2.617 2.654A3.003 3.003 0 0 0 0 13a3 3 0 1 0 5.878-.851l2.654-2.617.968.968-.305.914a1 1 0 0 0 .242 1.023l3.27 3.27a.997.997 0 0 0 1.414 0l1.586-1.586a.997.997 0 0 0 0-1.414l-3.27-3.27a1 1 0 0 0-1.023-.242L10.5 9.5l-.96-.96 2.68-2.643A3.005 3.005 0 0 0 16 3q0-.405-.102-.777l-2.14 2.141L12 4l-.364-1.757L13.777.102a3 3 0 0 0-3.675 3.68L7.462 6.46 4.793 3.793a1 1 0 0 1-.293-.707v-.071a1 1 0 0 0-.419-.814z"/>
        </svg>
        <h5 class="fw-semibold text-muted mb-2">Maintenance Staff Dashboard</h5>
        <p class="text-muted mb-3" style="font-size:.9rem;">Your dashboard is being built. Check back soon — you'll be able to view assigned jobs, update statuses, and upload repair evidence here.</p>
        <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary btn-sm px-4">Go to My Profile</a>
    </div>
</div>
