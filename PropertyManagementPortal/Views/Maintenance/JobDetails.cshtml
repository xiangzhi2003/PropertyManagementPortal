@using PropertyManagementPortal.ViewModels.Maintenance
@model JobDetailsViewModel
@{
    ViewData["Title"] = "Job Details";
    var (sbg, sfg) = Model.Status switch
    {
        "Completed" => ("#dcfce7", "#16a34a"),
        "InProgress" => ("#ede9fe", "#7c3aed"),
        "Assigned" => ("#dbeafe", "#2563eb"),
        _ => ("#fef3c7", "#d97706")
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">@Model.Category &mdash; Unit @Model.UnitNumber</h4>
        <span class="text-muted small">@Model.PropertyName</span>
    </div>
    <a asp-action="Jobs" class="btn btn-sm btn-outline-secondary">&larr; Back to Jobs</a>
</div>

<div class="row g-4">
    <!-- Left: issue details -->
    <div class="col-lg-7">
        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h6 class="section-heading mb-0">Issue Details</h6>
                    <div>
                        <span class="badge" style="background:@sbg;color:@sfg;">@Model.Status</span>
                        @if (!string.IsNullOrWhiteSpace(Model.Priority))
                        {
                            var (pbg, pfg) = Model.Priority switch
                            {
                                "High" => ("#fee2e2", "#dc2626"),
                                "Medium" => ("#fef3c7", "#d97706"),
                                _ => ("#f3f4f6", "#6b7280")
                            };
                            <span class="badge ms-1" style="background:@pbg;color:@pfg;">@Model.Priority priority</span>
                        }
                    </div>
                </div>

                <dl class="row mb-0 small">
                    <dt class="col-sm-3 text-muted fw-normal">Category</dt>
                    <dd class="col-sm-9">@Model.Category</dd>

                    <dt class="col-sm-3 text-muted fw-normal">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3 text-muted fw-normal">Reported by</dt>
                    <dd class="col-sm-9">
                        @Model.TenantName
                        @if (!string.IsNullOrWhiteSpace(Model.TenantPhone))
                        {
                            <span class="text-muted">&middot; @Model.TenantPhone</span>
                        }
                    </dd>

                    <dt class="col-sm-3 text-muted fw-normal">Reported on</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.AssignmentNotes))
                    {
                        <dt class="col-sm-3 text-muted fw-normal">Manager's note</dt>
                        <dd class="col-sm-9">@Model.AssignmentNotes</dd>
                    }
                </dl>
            </div>
        </div>

        <!-- Tenant's photo -->
        <div class="card">
            <div class="card-body p-4">
                <h6 class="section-heading mb-3">Reported Photo</h6>
                @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <img alt="Reported issue" class="img-fluid rounded border photo-resolve" style="max-height:340px;"
                         data-photo-key="@Model.PhotoUrl" />
                    <p class="text-muted small mb-0 mt-2 photo-loading">Loading photo&hellip;</p>
                }
                else
                {
                    <p class="text-muted small mb-0">No photo was attached to this request.</p>
                }
            </div>
        </div>
    </div>

    <!-- Right: status timeline -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="section-heading mb-0">Status History</h6>
                    @if (Model.Status != "Completed")
                    {
                        <button type="button" class="btn btn-sm btn-primary"
                                data-bs-toggle="modal" data-bs-target="#updateJobModal">
                            Update Status
                        </button>
                    }
                </div>

                @if (!Model.Updates.Any())
                {
                    <p class="text-muted small mb-0">No updates yet. When you start work, your updates will appear here.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var u in Model.Updates)
                        {
                            <div class="d-flex gap-3 align-items-start">
                                <div class="activity-dot mt-2"></div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold" style="font-size:.9rem;">@u.StatusUpdate</div>
                                    @if (!string.IsNullOrWhiteSpace(u.Notes))
                                    {
                                        <div class="text-muted" style="font-size:.85rem;">@u.Notes</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(u.EvidencePhotoUrl))
                                    {
                                        <a href="#" target="_blank" class="d-inline-block mt-2 evidence-link" data-photo-key="@u.EvidencePhotoUrl" style="display:none;">
                                            <img alt="Evidence" class="rounded border" style="max-height:120px;" />
                                        </a>
                                    }
                                    <div class="text-muted mt-1" style="font-size:.75rem;">
                                        @u.StaffName &middot; @u.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.Status != "Completed")
{
    // From Assigned the staffer may go to InProgress OR skip straight to Completed.
    // From InProgress the only forward move is Completed.
    var canChoose = Model.Status == "Assigned";

    <!-- Update status modal -->
    <div class="modal fade" id="updateJobModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content text-start">
                <form method="post" asp-action="UpdateJob" id="updateJobForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="RequestId" value="@Model.RequestId" />

                    <!-- Filled in by script once the browser has uploaded the evidence
                         photo straight to S3. -->
                    <input type="hidden" name="EvidenceObjectKey" id="evidenceObjectKey" />

                    <div class="modal-header">
                        <h5 class="modal-title">Update Job Status</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Move to <span class="text-danger">*</span></label>
                            @if (canChoose)
                            {
                                <select name="TargetStatus" id="targetStatus" class="form-select">
                                    <option value="InProgress">In Progress</option>
                                    <option value="Completed">Completed</option>
                                </select>
                            }
                            else
                            {
                                <input type="hidden" name="TargetStatus" value="Completed" />
                                <div><span class="badge" style="background:#dcfce7;color:#16a34a;">Completed</span></div>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Notes <span class="text-danger">*</span></label>
                            <textarea name="Notes" class="form-control" rows="4" maxlength="1000" required
                                      placeholder="Describe what was done..."></textarea>
                        </div>

                        <!-- Shown only when the target is Completed. -->
                        <div class="mb-1" id="evidenceField" style="@(canChoose ? "display:none;" : "")">
                            <label class="form-label">Evidence Photo <span class="text-danger">*</span></label>
                            <input id="evidencePhotoInput" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control"
                                   @(canChoose ? "" : "required") />
                            <div class="form-text">JPG, PNG or WEBP &middot; max 5 MB. Required to close the job.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="saveUpdateBtn">Save Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // API Gateway endpoint fronting the Lambda that mints presigned S3 URLs.
        var S3_ENDPOINT = '@(ViewBag.S3Endpoint ?? "")';

        var ALLOWED_EXTENSIONS = ['jpg', 'jpeg', 'png', 'webp'];
        var MAX_PHOTO_BYTES = 5 * 1024 * 1024;

        function callS3Api(payload) {
            return fetch(S3_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(function (res) {
                if (!res.ok) throw new Error('Request failed with status ' + res.status);
                return res.json();
            });
        }

        // ── Resolve every photo on the page (tenant's + evidence history) ───────
        (function () {
            if (!S3_ENDPOINT) return;

            document.querySelectorAll('.photo-resolve[data-photo-key]').forEach(function (img) {
                var loadingLabel = img.nextElementSibling;
                callS3Api({ action: 'getViewUrl', key: img.dataset.photoKey })
                    .then(function (data) {
                        if (!data.viewUrl) return;
                        img.src = data.viewUrl;
                        if (loadingLabel) loadingLabel.style.display = 'none';
                    })
                    .catch(function (err) {
                        console.error('Could not load photo', err);
                        if (loadingLabel) loadingLabel.textContent = 'Photo unavailable';
                    });
            });

            document.querySelectorAll('.evidence-link[data-photo-key]').forEach(function (link) {
                callS3Api({ action: 'getViewUrl', key: link.dataset.photoKey })
                    .then(function (data) {
                        if (!data.viewUrl) return;
                        link.href = data.viewUrl;
                        link.querySelector('img').src = data.viewUrl;
                        link.style.display = 'inline-block';
                    })
                    .catch(function (err) {
                        console.error('Could not load evidence photo', err);
                    });
            });
        })();

        // ── Update-status modal ─────────────────────────────────────────────────
        (function () {
            var form = document.getElementById('updateJobForm');
            if (!form) return;   // Completed job: no modal rendered

            var sel = document.getElementById('targetStatus');
            var field = document.getElementById('evidenceField');
            var fileInput = document.getElementById('evidencePhotoInput');
            var keyInput = document.getElementById('evidenceObjectKey');
            var saveBtn = document.getElementById('saveUpdateBtn');

            if (sel && field) {
                var sync = function () {
                    var completing = sel.value === 'Completed';
                    field.style.display = completing ? '' : 'none';
                    if (fileInput) fileInput.required = completing;
                };
                sel.addEventListener('change', sync);
                sync();
            }

            if (!fileInput || !keyInput) return;

            function validate(file) {
                var extension = file.name.split('.').pop().toLowerCase();
                if (ALLOWED_EXTENSIONS.indexOf(extension) === -1)
                    return 'Only JPG, PNG and WEBP images are accepted.';
                if (file.size === 0) return 'The selected file is empty.';
                if (file.size > MAX_PHOTO_BYTES) return 'The photo must be 5 MB or smaller.';
                return null;
            }

            var uploading = false;

            form.addEventListener('submit', function (e) {
                if (uploading) return;

                var file = fileInput.files[0];
                if (!file) return;   // not completing, or evidence not required yet

                e.preventDefault();

                if (!S3_ENDPOINT) {
                    alert('Photo upload is not configured yet. Please try again later.');
                    return;
                }

                var error = validate(file);
                if (error) { alert(error); return; }

                saveBtn.disabled = true;
                saveBtn.textContent = 'Uploading…';

                callS3Api({
                    action: 'getUploadUrl',
                    fileName: file.name,
                    contentType: file.type
                })
                    .then(function (data) {
                        if (!data.uploadUrl || !data.key) throw new Error('No upload URL returned');

                        return fetch(data.uploadUrl, {
                            method: 'PUT',
                            body: file,
                            headers: { 'Content-Type': file.type }
                        }).then(function (res) {
                            if (!res.ok) throw new Error('Upload failed with status ' + res.status);
                            return data.key;
                        });
                    })
                    .then(function (key) {
                        keyInput.value = key;
                        fileInput.required = false;
                        uploading = true;
                        saveBtn.textContent = 'Saving…';
                        form.submit();
                    })
                    .catch(function (err) {
                        console.error('Evidence upload failed', err);
                        alert('The photo could not be uploaded. Please check your connection and try again.');
                        saveBtn.disabled = false;
                        saveBtn.textContent = 'Save Update';
                    });
            });
        })();
    </script>
}
