@model List<PropertyManagementPortal.Models.MaintenanceRequest>

@{
    ViewData["Title"] = "My Maintenance Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">My Maintenance Requests</h4>

    <!-- Open submit modal -->
    <button class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        + Submit Request
    </button>
</div>


@if (!Model.Any())
{
    <div class="alert alert-info">
        No maintenance requests yet.
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">

            <table class="table table-hover mb-0 align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Property</th>
                        <th>Unit</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Photo</th>
                    </tr>
                </thead>


                <tbody>
                @foreach(var r in Model)
                {
                    <tr>
                        <td>@r.Unit.Property.Name</td>

                        <td>
                            Unit @r.Unit.UnitNumber
                        </td>

                        <td>
                            @r.Category
                        </td>

                        <td>
                            @r.Description
                        </td>

                        <td>
                            @if (!string.IsNullOrEmpty(r.PhotoUrl))
                            {
                                <a href="#" target="_blank" class="photo-link" data-photo-key="@r.PhotoUrl" style="display:none;">
                                    View Photo
                                </a>
                                <span class="text-muted photo-loading small">Loading&hellip;</span>
                            }
                            else
                            {
                                <span class="text-muted">No Photo</span>
                            }
                        </td>

                        <td>
                            @if(r.Status == "Assigned")
                            {
                                <span class="badge bg-warning text-dark">
                                    Assigned
                                </span>
                            }
                            else if(r.Status == "Completed")
                            {
                                <span class="badge bg-primary">
                                    Completed
                                </span>
                            }
                            else if(r.Status == "InProgress")
                            {
                                <span class="badge bg-primary">
                                    In Progress
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    Submitted
                                </span>
                            }
                        </td>

                        <td>
                            @r.CreatedAt.ToString("dd MMM yyyy")
                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>
    </div>
}

<!-- Submit Maintenance Modal -->

<div class="modal fade" id="createModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">


            <form asp-action="Maintenance" method="post" id="maintenanceForm">

                @Html.AntiForgeryToken()

                <!-- Filled in by script once the browser has uploaded the photo
                     straight to S3. Empty when no photo is attached. -->
                <input type="hidden" name="PhotoObjectKey" id="photoObjectKey" />


                <div class="modal-header">

                    <h5 class="modal-title">
                        Submit Maintenance Request
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>



                <div class="modal-body">


                    <label class="form-label">
                        Unit
                    </label>

                    <select name="UnitId"
                            class="form-select"
                            required>

                        @foreach(var item in ViewBag.Units)
                        {
                            <option value="@item.UnitId">
                                @item.Property.Name -
                                Unit @item.UnitNumber
                            </option>
                        }

                    </select>



                    <label class="form-label mt-3">
                        Category
                    </label>

                    <select name="Category"
                            class="form-select"
                            required>

                        <option value="">
                            -- Select Category --
                        </option>

                        <option>
                            Electrical
                        </option>

                        <option>
                            Plumbing
                        </option>

                        <option>
                            Cleaning
                        </option>

                        <option>
                            Furniture
                        </option>

                        <option>
                            Other
                        </option>

                    </select>



                    <label class="form-label mt-3">
                        Description
                    </label>

                    <textarea name="Description"
                              class="form-control"
                              rows="4"
                              required></textarea>
                    <label class="form-label mt-3">
                        Photo (Optional)
                    </label>

                    <input type="file"
                        id="photoInput"
                        class="form-control"
                        accept=".jpg,.jpeg,.png,.webp" />
                    <div class="form-text">JPG, PNG or WEBP &middot; max 5 MB.</div>


                </div>



                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>


                    <button class="btn btn-primary" id="submitRequestBtn">
                        Submit
                    </button>

                </div>


            </form>


        </div>

    </div>

</div>

@section Scripts {
    <script>
        // API Gateway endpoint fronting the Lambda that mints presigned S3 URLs.
        var S3_ENDPOINT = '@(ViewBag.S3Endpoint ?? "")';

        var ALLOWED_EXTENSIONS = ['jpg', 'jpeg', 'png', 'webp'];
        var MAX_PHOTO_BYTES = 5 * 1024 * 1024;

        function callS3Api(payload) {
            return fetch(S3_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(function (res) {
                if (!res.ok) throw new Error('Request failed with status ' + res.status);
                return res.json();
            });
        }

        // ── Resolve photo keys already stored on submitted requests ─────────────
        (function () {
            var links = document.querySelectorAll('.photo-link[data-photo-key]');
            if (!links.length || !S3_ENDPOINT) return;

            links.forEach(function (link) {
                var loadingLabel = link.nextElementSibling;
                callS3Api({ action: 'getViewUrl', key: link.dataset.photoKey })
                    .then(function (data) {
                        if (!data.viewUrl) return;
                        link.href = data.viewUrl;
                        link.style.display = '';
                        if (loadingLabel) loadingLabel.style.display = 'none';
                    })
                    .catch(function (err) {
                        console.error('Could not load photo', err);
                        if (loadingLabel) loadingLabel.textContent = 'Photo unavailable';
                    });
            });
        })();

        // ── Submit Request modal: upload photo straight to S3 before posting ────
        (function () {
            var form = document.getElementById('maintenanceForm');
            var fileInput = document.getElementById('photoInput');
            var keyInput = document.getElementById('photoObjectKey');
            var submitBtn = document.getElementById('submitRequestBtn');
            if (!form || !fileInput || !keyInput) return;

            function validate(file) {
                var extension = file.name.split('.').pop().toLowerCase();
                if (ALLOWED_EXTENSIONS.indexOf(extension) === -1)
                    return 'Only JPG, PNG and WEBP images are accepted.';
                if (file.size === 0) return 'The selected file is empty.';
                if (file.size > MAX_PHOTO_BYTES) return 'The photo must be 5 MB or smaller.';
                return null;
            }

            var uploading = false;

            form.addEventListener('submit', function (e) {
                if (uploading) return;   // second pass, after the upload finished

                var file = fileInput.files[0];
                if (!file) return;       // no photo attached — submit as-is

                e.preventDefault();

                if (!S3_ENDPOINT) {
                    alert('Photo upload is not configured yet. Submit without a photo, or try again later.');
                    return;
                }

                var error = validate(file);
                if (error) { alert(error); return; }

                submitBtn.disabled = true;
                submitBtn.textContent = 'Uploading…';

                callS3Api({
                    action: 'getUploadUrl',
                    fileName: file.name,
                    contentType: file.type
                })
                    .then(function (data) {
                        if (!data.uploadUrl || !data.key) throw new Error('No upload URL returned');

                        return fetch(data.uploadUrl, {
                            method: 'PUT',
                            body: file,
                            headers: { 'Content-Type': file.type }
                        }).then(function (res) {
                            if (!res.ok) throw new Error('Upload failed with status ' + res.status);
                            return data.key;
                        });
                    })
                    .then(function (key) {
                        keyInput.value = key;
                        uploading = true;
                        submitBtn.textContent = 'Saving…';
                        form.submit();
                    })
                    .catch(function (err) {
                        console.error('Photo upload failed', err);
                        alert('The photo could not be uploaded. Please check your connection and try again.');
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Submit';
                    });
            });
        })();
    </script>
}