@model List<PropertyManagementPortal.Models.MaintenanceRequest>

@{
    ViewData["Title"] = "My Maintenance Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">My Maintenance Requests</h4>

    <!-- Open submit modal -->
    <button class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        + Submit Request
    </button>
</div>


@if (!Model.Any())
{
    <div class="alert alert-info">
        No maintenance requests yet.
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">

            <table class="table table-hover mb-0 align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Property</th>
                        <th>Unit</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>


                <tbody>
                @foreach(var r in Model)
                {
                    <tr>
                        <td>@r.Unit.Property.Name</td>

                        <td>
                            Unit @r.Unit.UnitNumber
                        </td>

                        <td>
                            @r.Category
                        </td>

                        <td>
                            @r.Description
                        </td>

                        <td>
                            @if(r.Status == "Assigned")
                            {
                                <span class="badge bg-warning text-dark">
                                    Assigned
                                </span>
                            }
                            else if(r.Status == "Completed")
                            {
                                <span class="badge bg-primary">
                                    Completed
                                </span>
                            }
                            else if(r.Status == "InProgress")
                            {
                                <span class="badge bg-primary">
                                    In Progress
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    Submitted
                                </span>
                            }
                        </td>

                        <td>
                            @r.CreatedAt.ToString("dd MMM yyyy")
                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>
    </div>
}

<!-- Submit Maintenance Modal -->

<div class="modal fade" id="createModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">


            <form asp-action="Maintenance" method="post">

                @Html.AntiForgeryToken()


                <div class="modal-header">

                    <h5 class="modal-title">
                        Submit Maintenance Request
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>



                <div class="modal-body">


                    <label class="form-label">
                        Unit
                    </label>

                    <select name="UnitId"
                            class="form-select"
                            required>

                        @foreach(var item in ViewBag.Units)
                        {
                            <option value="@item.UnitId">
                                @item.Property.Name -
                                Unit @item.UnitNumber
                            </option>
                        }

                    </select>



                    <label class="form-label mt-3">
                        Category
                    </label>

                    <select name="Category"
                            class="form-select"
                            required>

                        <option value="">
                            -- Select Category --
                        </option>

                        <option>
                            Electrical
                        </option>

                        <option>
                            Plumbing
                        </option>

                        <option>
                            Cleaning
                        </option>

                        <option>
                            Furniture
                        </option>

                        <option>
                            Other
                        </option>

                    </select>



                    <label class="form-label mt-3">
                        Description
                    </label>

                    <textarea name="Description"
                              class="form-control"
                              rows="4"
                              required></textarea>


                </div>



                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>


                    <button class="btn btn-primary">
                        Submit
                    </button>

                </div>


            </form>


        </div>

    </div>

</div>