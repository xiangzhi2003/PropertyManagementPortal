@model PropertyManagementPortal.ViewModels.Tenant.ApplyUnitViewModel

@{
    ViewData["Title"] = "Apply for Unit";
}

<h3 class="fw-bold mb-4">Apply for Unit</h3>

<div class="card">

    <div class="card-body">

        <h5 class="mb-3">Unit Information</h5>

        <table class="table">

            <tr>
                <th width="200">Property</th>
                <td>@Model.PropertyName</td>
            </tr>

            <tr>
                <th>Unit</th>
                <td>@Model.UnitNumber</td>
            </tr>

            <tr>
                <th>Floor</th>
                <td>@Model.Floor</td>
            </tr>

            <tr>
                <th>Description</th>
                <td>@Model.Description</td>
            </tr>

            <tr>
                <th>Monthly Rent</th>
                <td>RM @Model.RentAmount.ToString("N2")</td>
            </tr>

        </table>

        <hr />

        <form asp-action="Apply" method="post">

            @Html.AntiForgeryToken()

            <input asp-for="UnitId" type="hidden" />
            <input asp-for="PropertyName" type="hidden" />
            <input asp-for="Floor" type="hidden" />
            <input asp-for="Description" type="hidden" />
            <input asp-for="UnitNumber" type="hidden" />
            <input asp-for="RentAmount" type="hidden" />

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label"></label>

                <input asp-for="StartDate"
                    id="startDate"
                    type="date"
                    class="form-control"
                    min="@DateTime.Today.ToString("yyyy-MM-dd")" />

                <span asp-validation-for="StartDate"
                    class="text-danger"></span>
            </div>


            <div class="mb-3">
                <label asp-for="EndDate" class="form-label"></label>

                <input asp-for="EndDate"
                    id="endDate"
                    type="date"
                    class="form-control"
                    min="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" />

                <span asp-validation-for="EndDate"
                    class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">

                <a asp-action="BrowseUnits"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>

                <button class="btn btn-primary">
                    Continue
                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const startDate = document.getElementById("startDate");
        const endDate = document.getElementById("endDate");

        startDate.addEventListener("change", function () {

            let selectedDate = new Date(this.value);

            selectedDate.setMonth(selectedDate.getMonth() + 1);

            let minEndDate = selectedDate.toISOString().split("T")[0];

            endDate.min = minEndDate;

            // reset end date if it becomes invalid
            if (endDate.value < minEndDate) {
                endDate.value = minEndDate;
            }
        });
    </script>
}