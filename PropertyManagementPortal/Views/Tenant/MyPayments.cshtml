@model List<PropertyManagementPortal.ViewModels.Tenant.PaymentViewModel>

@{
    ViewData["Title"] = "My Payments";
}

<h4 class="fw-bold mb-3">My Payments</h4>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No payment records found.
    </div>
}
else
{
    <div class="card">
        <div class="card-body">

            <table class="table table-hover">

                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Unit</th>
                        <th>Amount</th>
                        <th>Due Date</th>
                        <th>Payment Date</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.PropertyName</td>
                        <td>@p.UnitNumber</td>
                        <td>RM @p.Amount</td>
                        <td>@p.DueDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @(p.PaymentDate?.ToString("dd MMM yyyy") ?? "-")
                        </td>
                        <td>
                            @if (p.Status == "Paid")
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else if (p.Status == "Overdue")
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>

            </table>

        </div>
    </div>
}