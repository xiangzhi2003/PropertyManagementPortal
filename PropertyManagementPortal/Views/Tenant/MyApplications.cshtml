@model List<PropertyManagementPortal.Models.Tenancy>

@{
    ViewData["Title"] = "My Applications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">My Applications</h4>
        <span class="text-muted small">
            Track your rental applications and tenancy status.
        </span>
    </div>

    <span class="badge bg-primary">
        @Model.Count Application(s)
    </span>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You have not applied for any units yet.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead style="background:#f8fafc;">
                    <tr>
                        <th class="ps-4">Property</th>
                        <th>Unit</th>
                        <th>Lease Period</th>
                        <th>Rent</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                @foreach (var item in Model)
                {
                    var months = item.Payments.Count;

                    var total = item.Payments.Sum(p => p.Amount);

                    var (bg, fg) = item.Status switch
                    {
                        "Approved" => ("#dcfce7", "#16a34a"),
                        "Rejected" => ("#fee2e2", "#dc2626"),
                        _ => ("#fef3c7", "#d97706")
                    };

                    <tr>

                        <td class="ps-4">
                            <div class="fw-semibold">
                                @item.Unit.Property.Name
                            </div>

                            <small class="text-muted">
                                Applied @item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                            </small>
                        </td>

                        <td>
                            Unit @item.Unit.UnitNumber
                        </td>

                        <td>
                            <div>
                                @item.StartDate.ToString("dd MMM yyyy")
                            </div>

                            <small class="text-muted">
                                until @item.EndDate.ToString("dd MMM yyyy")
                            </small>
                        </td>

                        <td>
                            <div class="fw-semibold">
                                RM @item.Unit.RentAmount.ToString("N2") / month
                            </div>

                            <small class="text-muted">
                                @months month(s)
                            </small>

                            <br />

                            <small class="text-primary">
                                Total RM @total.ToString("N2")
                            </small>
                        </td>

                        <td>
                            @if (item.Status == "Approved")
                            {
                                var payment = item.Payments.FirstOrDefault();

                                if (payment == null || payment.Status != "Paid")
                                {
                                    <span class="badge"
                                        style="background:#dcfce7;color:#16a34a;">
                                        Approved
                                    </span>

                                    <br />

                                    <small class="text-warning">
                                        Awaiting payment
                                    </small>
                                }
                                else
                                {
                                    <span class="badge"
                                        style="background:#dcfce7;color:#16a34a;">
                                        Active
                                    </span>
                                }
                            }
                            else if (item.Status == "Rejected")
                            {
                                <span class="badge"
                                    style="background:#fee2e2;color:#dc2626;">
                                    Rejected
                                </span>
                            }
                            else
                            {
                                <span class="badge"
                                    style="background:#fef3c7;color:#d97706;">
                                    Pending
                                </span>
                            }

                            </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>
    </div>
}