@model PropertyManagementPortal.ViewModels.Admin.EditUserViewModel
@{ ViewData["Title"] = "Edit User"; }

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Users" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="fw-bold mb-0">Edit User</h4>
</div>

<div class="row g-4">
    <!-- Editable info -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-1">Account Information</h5>
                <p class="text-muted mb-4" style="font-size:.9rem;">Update this user's details and role assignment.</p>

                <form asp-action="EditUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="IsActive" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                        <label asp-for="FullName">Full Name</label>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Email" readonly />
                        <label asp-for="Email">Email Address</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone" />
                        <label asp-for="PhoneNumber">Phone Number (optional)</label>
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-4">
                        <select asp-for="Role" class="form-select">
                            <option value="Admin">Admin</option>
                            <option value="PropertyManager">Property Manager</option>
                            <option value="Tenant">Tenant</option>
                            <option value="MaintenanceStaff">Maintenance Staff</option>
                        </select>
                        <label asp-for="Role">Role</label>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg px-5">Save Changes</button>
                        <a asp-action="Users" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Read-only account info -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-body p-4">
                <!-- Avatar -->
                <div class="d-flex align-items-center gap-3 mb-4 pb-3" style="border-bottom:1px solid #f3f4f6;">
                    <div style="width:60px;height:60px;background:#dbeafe;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:#1d4ed8;flex-shrink:0;">
                        @(Model.FullName?.FirstOrDefault() ?? '?')
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:1.05rem;">@Model.FullName</div>
                        @{
                            var (roleBg, roleText) = Model.Role switch {
                                "Admin" => ("#1e3a5f", "white"),
                                "PropertyManager" => ("#dbeafe", "#1d4ed8"),
                                "Tenant" => ("#dcfce7", "#15803d"),
                                "MaintenanceStaff" => ("#fef3c7", "#92400e"),
                                _ => ("#f3f4f6", "#374151")
                            };
                        }
                        <span class="badge mt-1" style="background:@roleBg;color:@roleText;">
                            @(Model.Role == "MaintenanceStaff" ? "Maintenance Staff" : Model.Role == "PropertyManager" ? "Property Manager" : Model.Role)
                        </span>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-field-label">Email Address</div>
                    <div class="detail-field-value">@Model.Email</div>
                </div>
                <div class="detail-row">
                    <div class="detail-field-label">Account Status</div>
                    <div class="detail-field-value">
                        @if (Model.IsActive)
                        { <span class="badge bg-success">Active</span> }
                        else
                        { <span class="badge bg-secondary">Inactive</span> }
                    </div>
                </div>
                <div class="detail-row">
                    <div class="detail-field-label">Member Since</div>
                    <div class="detail-field-value">@Model.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy")</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
