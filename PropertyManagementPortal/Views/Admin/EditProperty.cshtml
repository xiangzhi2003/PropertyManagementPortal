@model PropertyManagementPortal.ViewModels.Admin.PropertyFormViewModel
@{ ViewData["Title"] = "Edit Property"; }

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Properties" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="fw-bold mb-0">Edit Property</h4>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-action="EditProperty" asp-route-id="@Model.PropertyId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PropertyId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Property Name" />
                <label asp-for="Name">Property Name</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Address" class="form-control" placeholder="Address" />
                <label asp-for="Address">Full Address</label>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <div class="form-floating mb-3">
                <select asp-for="Type" class="form-select">
                    @foreach (var t in PropertyManagementPortal.ViewModels.Admin.PropertyFormViewModel.PropertyTypes)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
                <label asp-for="Type">Property Type</label>
                <span asp-validation-for="Type" class="text-danger small"></span>
            </div>
            <div class="form-floating mb-4">
                <select asp-for="ManagerId" asp-items="Model.ManagerOptions" class="form-select">
                </select>
                <label asp-for="ManagerId">Assign Property Manager</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                <a asp-action="Properties" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
