@model PropertyManagementPortal.Models.Property
@{ ViewData["Title"] = "Property Details"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Properties" class="btn btn-outline-secondary">← Back to Properties</a>
    <h3 class="mb-0" style="font-size:1.4rem;font-weight:700;">Property Details</h3>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-body p-4">
                <!-- Property banner -->
                <div class="mb-4 pb-3" style="border-bottom:1px solid #f3f4f6;">
                    <div style="width:52px;height:52px;background:#dbeafe;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="#2563eb" viewBox="0 0 16 16">
                            <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L8 2.207l6.646 6.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293z"/>
                            <path d="M13 7.293V13.5a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-3h-2v3a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5V7.293l7-7z"/>
                        </svg>
                    </div>
                    <h4 class="fw-bold mb-1">@Model.Name</h4>
                    <span class="badge bg-light text-dark border me-1">@Model.Type</span>
                    @if (Model.Status == "Active")
                    { <span class="badge bg-success">Active</span> }
                    else
                    { <span class="badge bg-secondary">Inactive</span> }
                </div>

                <div class="detail-row">
                    <div class="detail-field-label">Address</div>
                    <div class="detail-field-value">@Model.Address</div>
                </div>
                <div class="detail-row">
                    <div class="detail-field-label">Property Manager</div>
                    <div class="detail-field-value">@(Model.Manager?.FullName ?? "Unassigned")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-field-label">Total Units</div>
                    <div class="detail-field-value fw-bold" style="font-size:1.2rem;">@Model.Units.Count</div>
                </div>
                <div class="detail-row">
                    <div class="detail-field-label">Created</div>
                    <div class="detail-field-value">@Model.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy")</div>
                </div>

                <div class="d-flex flex-column gap-2 mt-4">
                    <a asp-action="EditProperty" asp-route-id="@Model.PropertyId" class="btn btn-primary btn-lg">Edit Property</a>
                    <form asp-action="DeleteProperty" asp-route-id="@Model.PropertyId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-lg w-100 btn-outline-danger"
                                onclick="return confirm('Permanently delete @Model.Name and all its units? This cannot be undone.')">
                            Delete Property
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card table-card">
            <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="section-heading mb-0">Units (@Model.Units.Count)</h6>
                <button type="button" class="btn btn-primary btn-sm px-3"
                        data-bs-toggle="modal" data-bs-target="#addUnitModal">
                    + Add Unit
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Unit Number</th>
                            <th>Type</th>
                            <th>Floor</th>
                            <th>Rent (RM)</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in Model.Units.OrderBy(u => u.Floor).ThenBy(u => u.UnitNumber))
                        {
                            <tr>
                                <td class="fw-semibold">@unit.UnitNumber</td>
                                <td class="text-muted">@unit.Type</td>
                                <td class="text-muted">@unit.Floor</td>
                                <td class="fw-semibold">@unit.RentAmount.ToString("N2")</td>
                                <td>
                                    @if (unit.Status == "Occupied")
                                    { <span class="badge bg-success">Occupied</span> }
                                    else
                                    { <span class="badge bg-warning text-dark">Vacant</span> }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="EditUnit" asp-route-id="@unit.UnitId"
                                           class="btn btn-outline-primary btn-sm">Edit</a>
                                        <form asp-action="DeleteUnit" asp-route-id="@unit.UnitId" method="post"
                                              onsubmit="return confirm('Delete unit @unit.UnitNumber? This cannot be undone.')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Units.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-5">No units added yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add Unit Modal -->
<div class="modal fade" id="addUnitModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Add Unit</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddUnit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="propertyId" value="@Model.PropertyId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label detail-field-label">Unit Number <span class="text-danger">*</span></label>
                        <input type="text" name="unitNumber" class="form-control" maxlength="20" placeholder="e.g. A-01" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label class="form-label detail-field-label">Type <span class="text-danger">*</span></label>
                            <select name="type" class="form-select" required>
                                <option value="">Select type</option>
                                <option value="Studio">Studio</option>
                                <option value="1BR">1 Bedroom</option>
                                <option value="2BR">2 Bedrooms</option>
                                <option value="3BR">3 Bedrooms</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label detail-field-label">Floor <span class="text-danger">*</span></label>
                            <input type="number" name="floor" class="form-control" min="0" max="200" value="1" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label detail-field-label">Monthly Rent (RM) <span class="text-danger">*</span></label>
                        <input type="number" name="rentAmount" class="form-control" min="0" step="0.01" placeholder="0.00" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label detail-field-label">Description</label>
                        <textarea name="description" class="form-control" rows="2" maxlength="500"
                                  placeholder="Optional notes about this unit"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Add Unit</button>
                </div>
            </form>
        </div>
    </div>
</div>
