@model IEnumerable<PropertyManagementPortal.Models.RoleRequest>
@{ ViewData["Title"] = "Role Requests"; }

<div class="page-header mb-4">
    <h3 class="fw-bold mb-1">Role Requests</h3>
    <p class="text-muted mb-0">Review and approve or reject user role upgrade requests.</p>
</div>

<!-- Filter -->
<div class="card filter-card mb-4">
    <form method="get" class="d-flex align-items-end gap-3 flex-wrap">
        <div>
            <label class="detail-field-label d-block mb-1">Status</label>
            <select name="status" class="form-select form-select-sm" style="min-width:150px;" onchange="this.form.submit()">
                <option value="">All Requests</option>
                <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
            </select>
        </div>
        <a asp-action="RoleRequests" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>
</div>

<div class="card table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Requested Role</th>
                    <th>Requested At</th>
                    <th>Status</th>
                    <th>Reviewed By</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No role requests found.</td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@r.User.FullName</div>
                            <div class="text-muted" style="font-size:.82rem;">@r.User.Email</div>
                        </td>
                        <td>
                            @if (r.RequestedRole == "PropertyManager")
                            { <span class="badge" style="background:#dbeafe;color:#1d4ed8;">Property Manager</span> }
                            else
                            { <span class="badge" style="background:#fef3c7;color:#92400e;">Maintenance Staff</span> }
                        </td>
                        <td style="font-size:.88rem;">@r.RequestedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                        <td>
                            @if (r.Status == "Pending")
                            { <span class="badge bg-warning text-dark">Pending</span> }
                            else if (r.Status == "Approved")
                            { <span class="badge bg-success">Approved</span> }
                            else
                            { <span class="badge bg-danger">Rejected</span> }
                        </td>
                        <td style="font-size:.88rem;">
                            @if (r.ReviewedBy != null)
                            {
                                <div>@r.ReviewedBy</div>
                                <div class="text-muted" style="font-size:.78rem;">@r.ReviewedAt?.ToLocalTime().ToString("dd MMM yyyy")</div>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (r.Status == "Pending")
                            {
                                <div class="d-flex gap-2">
                                    <form asp-action="ApproveRoleRequest" asp-route-id="@r.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm px-3"
                                                onclick="return confirm('Approve this role request?')">Approve</button>
                                    </form>
                                    <button type="button" class="btn btn-danger btn-sm px-3"
                                            data-bs-toggle="modal" data-bs-target="#rejectModal-@r.Id">Reject</button>
                                </div>

                                <!-- Reject modal -->
                                <div class="modal fade" id="rejectModal-@r.Id" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Reject Role Request</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="RejectRoleRequest" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <div class="modal-body">
                                                    <p class="mb-3">Rejecting role request from <strong>@r.User.FullName</strong> for <strong>@(r.RequestedRole == "PropertyManager" ? "Property Manager" : "Maintenance Staff")</strong>.</p>
                                                    <div class="mb-3">
                                                        <label class="form-label detail-field-label">Reason (optional)</label>
                                                        <textarea name="adminNotes" class="form-control" rows="3" placeholder="Provide a reason for rejection..."></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(r.AdminNotes))
                            {
                                <span class="text-muted" style="font-size:.82rem;" title="@r.AdminNotes">
                                    <em>@(r.AdminNotes.Length > 40 ? r.AdminNotes[..40] + "…" : r.AdminNotes)</em>
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
