@model PropertyManagementPortal.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    const int plotHeight = 140;
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h3>Dashboard</h3>
        <p>Welcome back, <strong>@Model.AdminName</strong></p>
    </div>
    <span class="badge text-bg-light border fw-normal" style="font-size:.85rem;padding:.5rem .9rem;">
        @DateTime.Now.ToString("dddd, dd MMMM yyyy")
    </span>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a asp-action="Users" class="text-decoration-none">
            <div class="card stat-card" style="border-left:4px solid #2563eb;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Total Users</p>
                        <div class="stat-number" style="color:#2563eb;">@Model.TotalUsers</div>
                        <p class="stat-sub">Managers, Tenants &amp; Staff</p>
                    </div>
                    <div class="stat-icon" style="background:#dbeafe;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#2563eb" viewBox="0 0 16 16">
                            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72H7.022zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
                        </svg>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-action="Properties" class="text-decoration-none">
            <div class="card stat-card" style="border-left:4px solid #16a34a;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Properties</p>
                        <div class="stat-number" style="color:#16a34a;">@Model.TotalProperties</div>
                        <p class="stat-sub">Registered properties</p>
                    </div>
                    <div class="stat-icon" style="background:#dcfce7;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#16a34a" viewBox="0 0 16 16">
                            <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L8 2.207l6.646 6.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293z"/>
                            <path d="M13 7.293V13.5a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-3h-2v3a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5V7.293l7-7z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card" style="border-left:4px solid #d97706;">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="stat-label">Pending Maintenance</p>
                    <div class="stat-number" style="color:#d97706;">@Model.PendingMaintenance</div>
                    <p class="stat-sub">Submitted / In-Progress</p>
                </div>
                <div class="stat-icon" style="background:#fef3c7;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#d97706" viewBox="0 0 16 16">
                        <path d="M8.48 1.143a.5.5 0 0 0-.96 0l-.708 2.17a.5.5 0 0 1-.475.345H4.05a.5.5 0 0 0-.294.904l1.766 1.283a.5.5 0 0 1 .182.559l-.708 2.17a.5.5 0 0 0 .77.559L7.53 7.65a.5.5 0 0 1 .94 0l1.766 1.283a.5.5 0 0 0 .77-.559l-.708-2.17a.5.5 0 0 1 .182-.559l1.766-1.283a.5.5 0 0 0-.294-.904h-2.287a.5.5 0 0 1-.475-.345z"/>
                        <path d="M1.5 14a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 1 0v11a.5.5 0 0 1-.5.5m13 0a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 1 0v11a.5.5 0 0 1-.5.5"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card" style="border-left:4px solid #dc2626;">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="stat-label">Overdue Payments</p>
                    <div class="stat-number" style="color:#dc2626;">@Model.OverduePayments</div>
                    <p class="stat-sub">Requires attention</p>
                </div>
                <div class="stat-icon" style="background:#fee2e2;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#dc2626" viewBox="0 0 16 16">
                        <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.051zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- AI Property Report Summary -->
<div class="card mb-4">
    <div class="card-body p-4">
        @Html.AntiForgeryToken()
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="d-flex align-items-center gap-2">
                <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                     style="width:36px;height:36px;background:linear-gradient(135deg,#6d28d9,#2563eb);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" fill="#fff" viewBox="0 0 16 16">
                        <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"/>
                    </svg>
                </div>
                <div>
                    <h6 class="section-heading mb-1">AI Property Report</h6>
                    <p class="text-muted mb-0" style="font-size:.82rem;">A professional analysis of occupancy, rent collection, and maintenance, generated from your live data</p>
                </div>
            </div>
            <button type="button" id="aiSummaryBtn" class="btn btn-primary btn-sm px-3">
                <span id="aiSummaryBtnText">Generate AI Report</span>
                <span id="aiSummarySpinner" class="spinner-border spinner-border-sm ms-1 d-none" role="status" aria-hidden="true"></span>
            </button>
        </div>
        <div id="aiReport" class="d-none mt-3"></div>
        <div id="aiSummaryError" class="d-none mt-3 alert alert-danger mb-0" role="alert"></div>
    </div>
</div>

<!-- Occupancy Overview -->
<div class="card mb-4">
    <div class="card-body p-4">
        <h6 class="section-heading">Occupancy Overview</h6>
        <div class="row g-3 mb-4">
            <div class="col-sm-3">
                <div class="text-center p-4" style="background:#f0f4f8;border-radius:10px;">
                    <div class="fw-bold mb-1" style="font-size:2.25rem;line-height:1;color:#111827;">@Model.TotalUnits</div>
                    <div class="text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;font-weight:600;">Total Units</div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="text-center p-4" style="background:#dcfce7;border-radius:10px;">
                    <div class="fw-bold mb-1" style="font-size:2.25rem;line-height:1;color:#16a34a;">@Model.OccupiedUnits</div>
                    <div class="text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;font-weight:600;">Occupied</div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="text-center p-4" style="background:#fef3c7;border-radius:10px;">
                    <div class="fw-bold mb-1" style="font-size:2.25rem;line-height:1;color:#d97706;">@Model.VacantUnits</div>
                    <div class="text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;font-weight:600;">Vacant</div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="text-center p-4" style="background:#dbeafe;border-radius:10px;">
                    <div class="fw-bold mb-1" style="font-size:2.25rem;line-height:1;color:#2563eb;">@Model.OccupancyRate%</div>
                    <div class="text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;font-weight:600;">Occupancy Rate</div>
                </div>
            </div>
        </div>
        <div class="mb-1 d-flex justify-content-between align-items-center">
            <span class="small text-muted">Overall occupancy</span>
            <span class="small fw-semibold">@Model.OccupancyRate%</span>
        </div>
        <div class="progress" style="height:16px;border-radius:8px;">
            <div class="progress-bar bg-success" style="width:@Model.OccupancyRate%;border-radius:8px;" role="progressbar" aria-valuenow="@Model.OccupancyRate" aria-valuemin="0" aria-valuemax="100"></div>
        </div>

        @if (Model.OccupancyByProperty.Any())
        {
            <hr class="my-4" />
            <h6 class="section-heading mb-3">Occupancy by Property</h6>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead style="background:#f8fafc;">
                        <tr>
                            <th>Property</th>
                            <th class="text-center">Total Units</th>
                            <th class="text-center">Occupied</th>
                            <th class="text-center">Vacant</th>
                            <th style="min-width:180px;">Occupancy</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prop in Model.OccupancyByProperty)
                        {
                            <tr>
                                <td class="fw-semibold">@prop.PropertyName</td>
                                <td class="text-center">@prop.TotalUnits</td>
                                <td class="text-center" style="color:#16a34a;">@prop.OccupiedUnits</td>
                                <td class="text-center" style="color:#d97706;">@prop.VacantUnits</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:10px;border-radius:6px;">
                                            <div class="progress-bar bg-success" style="width:@prop.OccupancyRate%;border-radius:6px;"
                                                 role="progressbar" aria-valuenow="@prop.OccupancyRate" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <span class="small text-muted text-nowrap">@prop.OccupancyRate%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Payment & Maintenance charts -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <h6 class="section-heading mb-1">Payment Summary</h6>
                    <a asp-action="ExportPayments" class="btn btn-outline-secondary btn-sm">Export CSV</a>
                </div>
                <p class="text-muted mb-3" style="font-size:.82rem;">@Model.TotalPayments total payment record(s)</p>
                @{
                    var maxPayment = new[] { Model.PaidPayments, Model.PendingPayments, Model.OverduePayments }.Max();
                }
                @if (maxPayment == 0)
                {
                    <p class="text-muted mb-0 py-4 text-center">No payment records yet.</p>
                }
                else
                {
                    <div style="height:@(plotHeight + 44)px;">
                        <canvas id="paymentStatusChart" role="img" aria-label="Payment summary by status"></canvas>
                    </div>
                }

                @if (Model.UnpaidPaymentDetails.Any())
                {
                    <hr class="my-3" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="section-heading mb-0" style="font-size:.78rem;">Pending &amp; Overdue Payments</h6>
                        <span class="text-muted" style="font-size:.78rem;">@Model.UnpaidPaymentDetails.Count record(s)</span>
                    </div>
                    <div class="table-responsive" style="max-height:280px;overflow-y:auto;">
                        <table class="table table-sm align-middle mb-0">
                            <thead style="background:#f8fafc;position:sticky;top:0;">
                                <tr>
                                    <th>Tenant</th>
                                    <th>Property / Unit</th>
                                    <th>Manager</th>
                                    <th class="text-end">Amount</th>
                                    <th>Due Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.UnpaidPaymentDetails)
                                {
                                    <tr>
                                        <td class="small">
                                            <a asp-action="ViewUser" asp-route-id="@p.TenantId" class="text-decoration-none" title="@p.TenantEmail &#10;@p.TenantPhone">@p.TenantName</a>
                                        </td>
                                        <td class="small">@p.PropertyName &middot; Unit @p.UnitNumber</td>
                                        <td class="small">@(p.ManagerName ?? "—")</td>
                                        <td class="small text-end">RM @p.Amount.ToString("N2")</td>
                                        <td class="small">@p.DueDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (p.Status == "Overdue")
                                            {
                                                <span class="badge bg-danger">Overdue &middot; @p.DaysOverdue d</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body p-4">
                <h6 class="section-heading mb-1">Maintenance Summary</h6>
                <p class="text-muted mb-3" style="font-size:.82rem;">Requests grouped by current status</p>
                @{
                    var maxMaintenance = new[] { Model.SubmittedRequests, Model.AssignedRequests, Model.InProgressRequests, Model.CompletedRequests }.Max();
                }
                @if (maxMaintenance == 0)
                {
                    <p class="text-muted mb-0 py-4 text-center">No maintenance requests yet.</p>
                }
                else
                {
                    <div style="height:@(plotHeight + 44)px;">
                        <canvas id="maintenanceStatusChart" role="img" aria-label="Maintenance requests by status"></canvas>
                    </div>
                }

                @if (Model.OpenMaintenanceDetails.Any())
                {
                    var maintStatusColor = new Dictionary<string, (string bg, string fg)>
                    {
                        ["Submitted"] = ("#fef3c7", "#d97706"),
                        ["Assigned"] = ("#dbeafe", "#2563eb"),
                        ["InProgress"] = ("#ede9fe", "#7c3aed")
                    };
                    <hr class="my-3" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="section-heading mb-0" style="font-size:.78rem;">Open Requests</h6>
                        <span class="text-muted" style="font-size:.78rem;">@Model.OpenMaintenanceDetails.Count record(s)</span>
                    </div>
                    <div class="table-responsive" style="max-height:280px;overflow-y:auto;">
                        <table class="table table-sm align-middle mb-0">
                            <thead style="background:#f8fafc;position:sticky;top:0;">
                                <tr>
                                    <th>Property / Unit</th>
                                    <th>Category</th>
                                    <th>Tenant</th>
                                    <th>Manager</th>
                                    <th>Assigned Staff</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in Model.OpenMaintenanceDetails)
                                {
                                    var (mbg, mfg) = maintStatusColor.TryGetValue(m.Status, out var c) ? c : ("#f3f4f6", "#6b7280");
                                    <tr>
                                        <td class="small">@m.PropertyName &middot; Unit @m.UnitNumber</td>
                                        <td class="small">@m.Category</td>
                                        <td class="small">
                                            <a asp-action="ViewUser" asp-route-id="@m.TenantId" class="text-decoration-none" title="@m.TenantPhone">@m.TenantName</a>
                                        </td>
                                        <td class="small">@(m.ManagerName ?? "—")</td>
                                        <td class="small">
                                            @if (m.AssignedStaffId != null)
                                            {
                                                <a asp-action="ViewUser" asp-route-id="@m.AssignedStaffId" class="text-decoration-none">@m.AssignedStaffName</a>
                                            }
                                            else
                                            {
                                                <span>—</span>
                                            }
                                        </td>
                                        <td><span class="badge" style="background:@mbg;color:@mfg;">@m.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Trend charts -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body p-4">
                <h6 class="section-heading mb-1">Revenue Trend</h6>
                <p class="text-muted mb-3" style="font-size:.82rem;">Rent collected per month, last 6 months</p>
                @{
                    var maxRevenue = Model.RevenueTrend.Count == 0 ? 0 : Model.RevenueTrend.Max(r => r.Amount);
                }
                @if (maxRevenue == 0)
                {
                    <p class="text-muted mb-0 py-4 text-center">No payments collected in this period yet.</p>
                }
                else
                {
                    <div style="height:@(plotHeight + 44)px;">
                        <canvas id="revenueTrendChart" role="img" aria-label="Revenue collected per month for the last six months"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body p-4">
                <h6 class="section-heading mb-1">Occupancy Trend</h6>
                <p class="text-muted mb-3" style="font-size:.82rem;">Approximate occupancy rate per month, last 6 months</p>
                <div style="height:@(plotHeight + 44)px;">
                    <canvas id="occupancyTrendChart" role="img" aria-label="Occupancy rate per month for the last six months"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity (full width) -->
<div class="card">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="section-heading mb-0">Recent Activity</h6>
            <a asp-action="ActivityLog" class="btn btn-sm btn-outline-primary">View All Activity</a>
        </div>
        @{
            var recentLogs = ViewBag.RecentLogs as List<PropertyManagementPortal.Models.ActivityLog>;

            (string bg, string fg) ActivityColor(string action) => action switch
            {
                var a when a.StartsWith("Delet") || a.StartsWith("Reject") => ("#fee2e2", "#dc2626"),
                var a when a.StartsWith("Add") || a.StartsWith("Creat") || a.StartsWith("Approv") || a.StartsWith("Activat") => ("#dcfce7", "#16a34a"),
                var a when a.StartsWith("Edit") || a.StartsWith("Updat") => ("#dbeafe", "#2563eb"),
                _ => ("#f3f4f6", "#6b7280")
            };
        }
        @if (recentLogs != null && recentLogs.Any())
        {
            @foreach (var log in recentLogs)
            {
                var (abg, afg) = ActivityColor(log.Action);
                <div class="activity-item">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="activity-dot mt-2" style="background:@afg;"></div>
                        <div>
                            <span class="badge" style="background:@abg;color:@afg;font-weight:500;">@log.Action</span>
                            @if (!string.IsNullOrEmpty(log.EntityType))
                            {
                                <span class="text-muted ms-1" style="font-size:.78rem;">@log.EntityType</span>
                            }
                            @if (!string.IsNullOrEmpty(log.Details))
                            {
                                <div class="text-muted mt-1" style="font-size:.88rem;">@log.Details</div>
                            }
                            <div class="text-muted mt-1" style="font-size:.8rem;">by @log.UserName</div>
                        </div>
                    </div>
                    <span class="text-muted text-nowrap" style="font-size:.82rem;">
                        @log.Timestamp.ToLocalTime().ToString("dd MMM, HH:mm")
                    </span>
                </div>
            }
        }
        else
        {
            <p class="text-muted mb-0 py-3 text-center">No recent activity recorded yet.</p>
        }
    </div>
</div>

@{
    var maxPaymentForChart = new[] { Model.PaidPayments, Model.PendingPayments, Model.OverduePayments }.Max();
    var maxMaintenanceForChart = new[] { Model.SubmittedRequests, Model.AssignedRequests, Model.InProgressRequests, Model.CompletedRequests }.Max();
    var maxRevenueForChart = Model.RevenueTrend.Count == 0 ? 0 : Model.RevenueTrend.Max(r => r.Amount);
    var revenueLabels = string.Join(",", Model.RevenueTrend.Select(r => $"'{r.Label}'"));
    var revenueAmounts = string.Join(",", Model.RevenueTrend.Select(r => r.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)));
    var occupancyLabels = string.Join(",", Model.OccupancyTrend.Select(r => $"'{r.Label}'"));
    var occupancyRates = string.Join(",", Model.OccupancyTrend.Select(r => r.Rate.ToString(System.Globalization.CultureInfo.InvariantCulture)));
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script>
        @if (maxPaymentForChart > 0)
        {
            <text>
        new Chart(document.getElementById('paymentStatusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Paid', 'Pending', 'Overdue'],
                datasets: [{
                    data: [@Model.PaidPayments, @Model.PendingPayments, @Model.OverduePayments],
                    backgroundColor: ['#16a34a', '#d97706', '#dc2626'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });
            </text>
        }

        @if (maxMaintenanceForChart > 0)
        {
            <text>
        new Chart(document.getElementById('maintenanceStatusChart'), {
            type: 'bar',
            data: {
                labels: ['Submitted', 'Assigned', 'In Progress', 'Completed'],
                datasets: [{
                    label: 'Requests',
                    data: [@Model.SubmittedRequests, @Model.AssignedRequests, @Model.InProgressRequests, @Model.CompletedRequests],
                    backgroundColor: ['#d97706', '#2563eb', '#7c3aed', '#16a34a'],
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });
            </text>
        }

        @if (maxRevenueForChart > 0)
        {
            <text>
        new Chart(document.getElementById('revenueTrendChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(revenueLabels)],
                datasets: [{
                    label: 'Revenue (RM)',
                    data: [@Html.Raw(revenueAmounts)],
                    borderColor: '#16a34a',
                    backgroundColor: 'rgba(22, 163, 74, 0.12)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });
            </text>
        }

        new Chart(document.getElementById('occupancyTrendChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(occupancyLabels)],
                datasets: [{
                    label: 'Occupancy (%)',
                    data: [@Html.Raw(occupancyRates)],
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.12)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, max: 100 } }
            }
        });

        // Color palettes for the AI report badges (keyed by the values the schema allows).
        const aiHealthColors = {
            'Excellent': { bg: '#dcfce7', fg: '#15803d' },
            'Good':      { bg: '#dcfce7', fg: '#16a34a' },
            'Fair':      { bg: '#fef3c7', fg: '#d97706' },
            'Needs Attention': { bg: '#fee2e2', fg: '#dc2626' }
        };
        const aiStatusColors = {
            'Good':     { bg: '#dcfce7', fg: '#16a34a', dot: '#16a34a' },
            'Warning':  { bg: '#fef3c7', fg: '#d97706', dot: '#d97706' },
            'Critical': { bg: '#fee2e2', fg: '#dc2626', dot: '#dc2626' }
        };

        function aiBadge(text, colors) {
            const span = document.createElement('span');
            span.className = 'badge';
            span.style.background = colors.bg;
            span.style.color = colors.fg;
            span.style.fontWeight = '600';
            span.textContent = text;
            return span;
        }

        function aiSectionHeading(text) {
            const h = document.createElement('div');
            h.className = 'fw-semibold text-uppercase text-muted mb-2';
            h.style.cssText = 'font-size:.72rem;letter-spacing:.06em;';
            h.textContent = text;
            return h;
        }

        // A small stat tile (value + label) for the "portfolio at a glance" row.
        function aiTile(value, label, color) {
            const col = document.createElement('div');
            col.className = 'col';
            const box = document.createElement('div');
            box.className = 'text-center p-3 h-100';
            box.style.cssText = 'background:#f0f4f8;border-radius:10px;';
            const v = document.createElement('div');
            v.className = 'fw-bold';
            v.style.cssText = 'font-size:1.6rem;line-height:1;color:' + (color || '#111827') + ';';
            v.textContent = value;
            const l = document.createElement('div');
            l.className = 'text-muted mt-1';
            l.style.cssText = 'font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;font-weight:600;';
            l.textContent = label;
            box.appendChild(v);
            box.appendChild(l);
            col.appendChild(box);
            return col;
        }

        // Build a styled table. columns = [{header, key, align?, render?(row)->node|string}]
        function aiTable(columns, rows, emptyText) {
            const wrap = document.createElement('div');
            wrap.className = 'table-responsive';
            const table = document.createElement('table');
            table.className = 'table table-sm align-middle mb-0';

            const thead = document.createElement('thead');
            thead.style.background = '#f8fafc';
            const htr = document.createElement('tr');
            columns.forEach(function (c) {
                const th = document.createElement('th');
                th.textContent = c.header;
                if (c.align === 'center') th.className = 'text-center';
                if (c.align === 'end') th.className = 'text-end';
                htr.appendChild(th);
            });
            thead.appendChild(htr);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            if (!rows || rows.length === 0) {
                const tr = document.createElement('tr');
                const td = document.createElement('td');
                td.colSpan = columns.length;
                td.className = 'text-center text-muted py-3';
                td.textContent = emptyText || 'No data.';
                tr.appendChild(td);
                tbody.appendChild(tr);
            } else {
                rows.forEach(function (row) {
                    const tr = document.createElement('tr');
                    columns.forEach(function (c) {
                        const td = document.createElement('td');
                        td.className = 'small';
                        if (c.align === 'center') td.className += ' text-center';
                        if (c.align === 'end') td.className += ' text-end';
                        const content = c.render ? c.render(row) : row[c.key];
                        if (content instanceof Node) td.appendChild(content);
                        else td.textContent = (content === null || content === undefined) ? '' : String(content);
                        tr.appendChild(td);
                    });
                    tbody.appendChild(tr);
                });
            }
            table.appendChild(tbody);
            wrap.appendChild(table);
            return wrap;
        }

        function renderAiReport(report, facts) {
            const root = document.getElementById('aiReport');
            root.innerHTML = '';

            // ── Overall health verdict ──────────────────────────────────────
            const header = document.createElement('div');
            header.className = 'd-flex align-items-center gap-2 mb-3';
            const verdictLabel = document.createElement('span');
            verdictLabel.className = 'text-muted small';
            verdictLabel.textContent = 'Overall Health:';
            header.appendChild(verdictLabel);
            header.appendChild(aiBadge(report.overallHealth, aiHealthColors[report.overallHealth] || aiStatusColors['Warning']));
            root.appendChild(header);

            // ── Portfolio at a glance (factual tiles) ───────────────────────
            if (facts) {
                root.appendChild(aiSectionHeading('Portfolio at a Glance'));
                const tiles = document.createElement('div');
                tiles.className = 'row row-cols-2 row-cols-md-4 row-cols-xl-6 g-2 mb-3';
                tiles.appendChild(aiTile(facts.totalProperties, 'Properties'));
                tiles.appendChild(aiTile(facts.totalUnits, 'Units'));
                tiles.appendChild(aiTile(facts.occupancyRate + '%', 'Occupancy', '#2563eb'));
                tiles.appendChild(aiTile(facts.activeTenants, 'Active Tenants', '#16a34a'));
                tiles.appendChild(aiTile(facts.totalManagers, 'Managers'));
                tiles.appendChild(aiTile(facts.totalStaff, 'Staff'));
                root.appendChild(tiles);
            }

            // ── Executive summary ───────────────────────────────────────────
            const summary = document.createElement('div');
            summary.className = 'p-3 mb-3';
            summary.style.cssText = 'background:#eef2ff;border-left:4px solid #6d28d9;border-radius:8px;font-size:.95rem;line-height:1.6;';
            summary.textContent = report.executiveSummary;
            root.appendChild(summary);

            // ── Area analysis cards (AI) ────────────────────────────────────
            const grid = document.createElement('div');
            grid.className = 'row g-3 mb-3';
            (report.sections || []).forEach(function (s) {
                const colors = aiStatusColors[s.status] || aiStatusColors['Warning'];
                const col = document.createElement('div');
                col.className = 'col-md-4';
                const card = document.createElement('div');
                card.className = 'h-100 p-3';
                card.style.cssText = 'border:1px solid #e5e7eb;border-radius:10px;border-left:4px solid ' + colors.dot + ';';
                const top = document.createElement('div');
                top.className = 'd-flex justify-content-between align-items-center mb-2';
                const title = document.createElement('span');
                title.className = 'fw-semibold';
                title.style.fontSize = '.9rem';
                title.textContent = s.title;
                top.appendChild(title);
                top.appendChild(aiBadge(s.status, colors));
                card.appendChild(top);
                const insight = document.createElement('div');
                insight.className = 'text-muted';
                insight.style.cssText = 'font-size:.85rem;line-height:1.5;';
                insight.textContent = s.insight;
                card.appendChild(insight);
                col.appendChild(card);
                grid.appendChild(col);
            });
            root.appendChild(grid);

            // ── Per-property table (factual) ────────────────────────────────
            if (facts && facts.properties) {
                root.appendChild(aiSectionHeading('Properties'));
                const propTable = aiTable([
                    { header: 'Property', render: function (r) { const s = document.createElement('span'); s.className = 'fw-semibold'; s.textContent = r.name; return s; } },
                    { header: 'Manager', key: 'manager' },
                    { header: 'Units', key: 'units', align: 'center' },
                    { header: 'Occupied', key: 'occupied', align: 'center' },
                    { header: 'Tenants', key: 'tenants', align: 'center' },
                    { header: 'Overdue', align: 'center', render: function (r) { if (r.overdue > 0) { return aiBadge(String(r.overdue), aiStatusColors['Critical']); } const s = document.createElement('span'); s.className = 'text-muted'; s.textContent = '0'; return s; } },
                    { header: 'Open Jobs', align: 'center', render: function (r) { if (r.openMaintenance > 0) { return aiBadge(String(r.openMaintenance), aiStatusColors['Warning']); } const s = document.createElement('span'); s.className = 'text-muted'; s.textContent = '0'; return s; } }
                ], facts.properties, 'No properties registered yet.');
                propTable.classList.add('mb-3');
                root.appendChild(propTable);
            }

            // ── Team (factual): managers + staff side by side ───────────────
            if (facts) {
                const teamRow = document.createElement('div');
                teamRow.className = 'row g-3 mb-3';

                const mCol = document.createElement('div');
                mCol.className = 'col-md-6';
                mCol.appendChild(aiSectionHeading('Property Managers'));
                mCol.appendChild(aiTable([
                    { header: 'Manager', render: function (r) { const s = document.createElement('span'); s.className = 'fw-semibold'; s.textContent = r.name; return s; } },
                    { header: 'Properties', key: 'properties', align: 'center' },
                    { header: 'Units', key: 'units', align: 'center' }
                ], facts.managers, 'No property managers.'));
                teamRow.appendChild(mCol);

                const sCol = document.createElement('div');
                sCol.className = 'col-md-6';
                sCol.appendChild(aiSectionHeading('Maintenance Staff'));
                sCol.appendChild(aiTable([
                    { header: 'Staff', render: function (r) { const s = document.createElement('span'); s.className = 'fw-semibold'; s.textContent = r.name; return s; } },
                    { header: 'Open Jobs', align: 'center', render: function (r) { if (r.openJobs > 0) { return aiBadge(String(r.openJobs), aiStatusColors['Warning']); } const s = document.createElement('span'); s.className = 'text-muted'; s.textContent = '0'; return s; } },
                    { header: 'Completed', key: 'completed', align: 'center' }
                ], facts.staff, 'No maintenance staff.'));
                teamRow.appendChild(sCol);

                root.appendChild(teamRow);
            }

            // ── Priority actions (AI) ───────────────────────────────────────
            if (report.priorityActions && report.priorityActions.length) {
                const wrap = document.createElement('div');
                wrap.className = 'p-3';
                wrap.style.cssText = 'background:#fffbeb;border:1px solid #fde68a;border-radius:10px;';
                const heading = document.createElement('div');
                heading.className = 'fw-semibold mb-2';
                heading.style.cssText = 'font-size:.85rem;color:#92400e;';
                heading.textContent = 'Priority Actions';
                wrap.appendChild(heading);
                const list = document.createElement('ol');
                list.className = 'mb-0 ps-3';
                list.style.cssText = 'font-size:.88rem;line-height:1.7;';
                report.priorityActions.forEach(function (a) {
                    const li = document.createElement('li');
                    li.textContent = a;
                    list.appendChild(li);
                });
                wrap.appendChild(list);
                root.appendChild(wrap);
            }

            root.classList.remove('d-none');
        }

        document.getElementById('aiSummaryBtn').addEventListener('click', async function () {
            const btn = document.getElementById('aiSummaryBtn');
            const btnText = document.getElementById('aiSummaryBtnText');
            const spinner = document.getElementById('aiSummarySpinner');
            const reportEl = document.getElementById('aiReport');
            const errorCard = document.getElementById('aiSummaryError');
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            btn.disabled = true;
            btnText.textContent = 'Analysing...';
            spinner.classList.remove('d-none');
            reportEl.classList.add('d-none');
            errorCard.classList.add('d-none');

            try {
                const response = await fetch('@Url.Action("GenerateAiSummary", "Admin")', {
                    method: 'POST',
                    headers: { 'X-CSRF-TOKEN': token }
                });
                const data = await response.json();

                if (data.error || !data.report) {
                    errorCard.textContent = data.error || 'The AI returned an unexpected response. Please try again.';
                    errorCard.classList.remove('d-none');
                } else {
                    renderAiReport(data.report, data.facts);
                }
            } catch (err) {
                errorCard.textContent = 'Something went wrong generating the report. Please try again.';
                errorCard.classList.remove('d-none');
            } finally {
                btn.disabled = false;
                btnText.textContent = 'Regenerate Report';
                spinner.classList.add('d-none');
            }
        });
    </script>
}
