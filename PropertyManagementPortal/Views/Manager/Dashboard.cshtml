@model PropertyManagementPortal.ViewModels.Manager.ManagerDashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<!-- Welcome header -->
<div class="d-flex align-items-center gap-3 mb-4">
    <div style="width:52px;height:52px;background:#dbeafe;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:#1d4ed8;flex-shrink:0;">
        @(Model.ManagerName?.FirstOrDefault() ?? '?')
    </div>
    <div>
        <h4 class="fw-bold mb-0">Welcome, @Model.ManagerName</h4>
        <span class="badge" style="background:#dbeafe;color:#1d4ed8;">Property Manager</span>
    </div>
</div>

@if (Model.TotalProperties == 0)
{
    <div class="alert alert-info">
        No property has been assigned to you yet. Once an administrator assigns you a property, your units, tenants, and requests will appear here.
    </div>
}

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <!-- Units overview -->
    <div class="col-sm-6 col-xl-3">
        <a asp-action="Units" class="text-decoration-none">
            <div class="card stat-card" style="border-left:4px solid #2563eb;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Total Units</p>
                        <div class="stat-number" style="color:#2563eb;">@Model.TotalUnits</div>
                        <p class="stat-sub">@Model.OccupiedUnits occupied &middot; @Model.VacantUnits vacant</p>
                    </div>
                    <div class="stat-icon" style="background:#dbeafe;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#2563eb" viewBox="0 0 16 16">
                            <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3A1.5 1.5 0 0 1 15 10.5v3A1.5 1.5 0 0 1 13.5 15h-3A1.5 1.5 0 0 1 9 13.5z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Pending applications -->
    <div class="col-sm-6 col-xl-3">
        <a asp-action="Applications" asp-route-status="Pending" class="text-decoration-none">
            <div class="card stat-card" style="border-left:4px solid #d97706;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Pending Applications</p>
                        <div class="stat-number" style="color:#d97706;">@Model.PendingApplications</div>
                        <p class="stat-sub">Awaiting your review</p>
                    </div>
                    <div class="stat-icon" style="background:#fef3c7;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#d97706" viewBox="0 0 16 16">
                            <path d="M12.5 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7m1.679-4.493-1.335 2.226a.75.75 0 0 1-1.174.144l-.774-.773a.5.5 0 0 1 .708-.708l.547.548 1.17-1.951a.5.5 0 1 1 .858.514ZM11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0M8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4"/>
                            <path d="M8.256 14a4.5 4.5 0 0 1-.229-1.004H3c.001-.246.154-.986.832-1.664C4.484 10.68 5.711 10 8 10q.39 0 .74.025c.226-.341.496-.65.804-.918Q8.844 9.002 8 9c-5 0-6 3-6 4s1 1 1 1z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Rent dues -->
    <div class="col-sm-6 col-xl-3">
        <a asp-action="Payments" asp-route-status="Overdue" class="text-decoration-none">
            <div class="card stat-card" style="border-left:4px solid #dc2626;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Overdue Rent</p>
                        <div class="stat-number" style="color:#dc2626;">@Model.OverduePayments</div>
                        <p class="stat-sub">@Model.PendingPayments pending &middot; overdue payments</p>
                    </div>
                    <div class="stat-icon" style="background:#fee2e2;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#dc2626" viewBox="0 0 16 16">
                            <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.051zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Unassigned maintenance -->
    <div class="col-sm-6 col-xl-3">
        <a asp-action="Maintenance" asp-route-status="Submitted" class="text-decoration-none">
            <div class="card stat-card" style="border-left:4px solid #7c3aed;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Unassigned Maintenance</p>
                        <div class="stat-number" style="color:#7c3aed;">@Model.UnassignedMaintenance</div>
                        <p class="stat-sub">Needs a staff assignment</p>
                    </div>
                    <div class="stat-icon" style="background:#ede9fe;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#7c3aed" viewBox="0 0 16 16">
                            <path d="M1 0 0 1l2.2 3.081a1 1 0 0 0 .815.419h.07a1 1 0 0 1 .708.293l2.675 2.675-2.617 2.654A3.003 3.003 0 0 0 0 13a3 3 0 1 0 5.878-.851l2.654-2.617.968.968-.305.914a1 1 0 0 0 .242 1.023l3.27 3.27a.997.997 0 0 0 1.414 0l1.586-1.586a.997.997 0 0 0 0-1.414l-3.27-3.27a1 1 0 0 0-1.023-.242L10.5 9.5l-.96-.96 2.68-2.643A3.005 3.005 0 0 0 16 3q0-.405-.102-.777l-2.14 2.141L12 4l-.364-1.757L13.777.102a3 3 0 0 0-3.675 3.68L7.462 6.46 4.793 3.793a1 1 0 0 1-.293-.707v-.071a1 1 0 0 0-.419-.814zm9.646 10.646a.5.5 0 0 1 .708 0l2.5 2.5a.5.5 0 0 1-.708.708l-2.5-2.5a.5.5 0 0 1 0-.708M3 11l.471.242.529.026.287.445.445.287.026.529L5 13.5l-.242.471-.026.529-.445.287-.287.445-.529.026L3 15.5l-.471-.242L2 15.232l-.287-.445L1.268 14.5l-.026-.529L1 13.5l.242-.471.026-.529.445-.287.287-.445.529-.026z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Occupancy overview -->
<div class="card">
    <div class="card-body p-4">
        <h6 class="section-heading mb-3">Occupancy Overview</h6>
        <div class="mb-1 d-flex justify-content-between align-items-center">
            <span class="small text-muted">@Model.OccupiedUnits of @Model.TotalUnits units occupied</span>
            <span class="small fw-semibold">@Model.OccupancyRate%</span>
        </div>
        <div class="progress" style="height:16px;border-radius:8px;">
            <div class="progress-bar bg-success" style="width:@Model.OccupancyRate%;border-radius:8px;"
                 role="progressbar" aria-valuenow="@Model.OccupancyRate" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>
</div>
