@using PropertyManagementPortal.ViewModels.Manager
@model MaintenanceListViewModel
@{ ViewData["Title"] = "Maintenance"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Maintenance Tasks</h4>
        <span class="text-muted small">Assign submitted requests to your maintenance staff</span>
    </div>
    @if (Model.UnassignedCount > 0)
    {
        <span class="badge bg-warning text-dark" style="font-size:.85rem;">@Model.UnassignedCount unassigned</span>
    }
</div>

@if (!Model.StaffOptions.Any())
{
    <div class="alert alert-warning">
        There are no active maintenance staff to assign requests to yet. Ask an administrator to add or activate a Maintenance Staff account.
    </div>
}

<!-- Filter bar -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Maintenance" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Property</label>
                <select name="propertyId" class="form-select form-select-sm" asp-items="Model.PropertyOptions">
                    <option value="">All properties</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All statuses</option>
                    @foreach (var s in new[] { "Submitted", "Assigned", "InProgress", "Completed" })
                    {
                        <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary flex-grow-1">Filter</button>
                <a asp-action="Maintenance" class="btn btn-sm btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8fafc;">
                    <tr>
                        <th class="ps-3">Request</th>
                        <th>Property / Unit</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Requests.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No maintenance requests found.</td></tr>
                    }
                    else
                    {
                        @foreach (var r in Model.Requests)
                        {
                            var (sbg, sfg) = r.Status switch
                            {
                                "Completed" => ("#dcfce7", "#16a34a"),
                                "InProgress" => ("#ede9fe", "#7c3aed"),
                                "Assigned" => ("#dbeafe", "#2563eb"),
                                _ => ("#fef3c7", "#d97706")
                            };

                            // Hoisted to row scope so both the priority cell and the
                            // detail modal below can use them.
                            var (pbg, pfg) = r.Priority switch
                            {
                                "High" => ("#fee2e2", "#dc2626"),
                                "Medium" => ("#fef3c7", "#d97706"),
                                _ => ("#f3f4f6", "#6b7280")
                            };
                            <tr style="cursor:pointer;" class="maintenance-row" data-detail-target="#detailModal-@r.RequestId">
                                <td class="ps-3" style="max-width:280px;">
                                    <div class="fw-semibold">@r.Category</div>
                                    <div class="text-muted" style="font-size:.8rem;">@r.Description</div>
                                    <div class="text-muted" style="font-size:.72rem;">by @r.TenantName &middot; @r.CreatedAt.ToString("dd MMM yyyy")</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@r.PropertyName</div>
                                    <div class="text-muted" style="font-size:.8rem;">Unit @r.UnitNumber</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(r.Priority))
                                    {
                                        <span class="badge" style="background:@pbg;color:@pfg;">@r.Priority</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }
                                </td>
                                <td><span class="badge" style="background:@sbg;color:@sfg;">@r.Status</span></td>
                                <td class="small">@(string.IsNullOrWhiteSpace(r.AssignedStaffName) ? "—" : r.AssignedStaffName)</td>
                                <td class="text-end pe-3">
                                    @if (r.Status != "Completed" && Model.StaffOptions.Any())
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal" data-bs-target="#assignModal-@r.RequestId">
                                            @(r.Status == "Submitted" ? "Assign" : "Reassign")
                                        </button>

                                        <!-- Assign modal -->
                                        <div class="modal fade" id="assignModal-@r.RequestId" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <form method="post" asp-action="AssignRequest">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@r.RequestId" />
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Assign Maintenance Task</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p class="small text-muted mb-3">
                                                                <strong>@r.Category</strong> — @r.PropertyName, Unit @r.UnitNumber
                                                            </p>
                                                            <div class="mb-3">
                                                                <label class="form-label">Assign to</label>
                                                                <select name="staffId" class="form-select" asp-items="Model.StaffOptions" required>
                                                                    <option value="">Select staff</option>
                                                                </select>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Priority</label>
                                                                <select name="priority" class="form-select" required>
                                                                    @foreach (var pr in MaintenanceListViewModel.Priorities)
                                                                    {
                                                                        <option value="@pr" selected="@(r.Priority == pr)">@pr</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="mb-1">
                                                                <label class="form-label">Notes <span class="text-muted small">(optional)</span></label>
                                                                <textarea name="notes" class="form-control" rows="3" maxlength="1000"
                                                                        placeholder="Instructions for the staff...">@r.AssignmentNotes</textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-primary">Assign Task</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }

                                    <!-- Detail modal -->
                                    <div class="modal fade text-start" id="detailModal-@r.RequestId" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <div>
                                                        <h5 class="modal-title mb-0">@r.Category &mdash; Unit @r.UnitNumber</h5>
                                                        <span class="text-muted" style="font-size:.82rem;">@r.PropertyName</span>
                                                    </div>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="row g-3 mb-3">
                                                        <div class="col-sm-6">
                                                            <div class="text-muted" style="font-size:.75rem;">REPORTED BY</div>
                                                            <div class="fw-semibold">@r.TenantName</div>
                                                            <div class="text-muted" style="font-size:.8rem;">@r.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div>
                                                        </div>
                                                        <div class="col-sm-6">
                                                            <div class="text-muted mb-1" style="font-size:.75rem;">STATUS</div>
                                                            <span class="badge" style="background:@sbg;color:@sfg;">@r.Status</span>
                                                            @if (!string.IsNullOrWhiteSpace(r.Priority))
                                                            {
                                                                <span class="badge ms-1" style="background:@pbg;color:@pfg;">@r.Priority priority</span>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <div class="text-muted" style="font-size:.75rem;">DESCRIPTION</div>
                                                        <div>@r.Description</div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <div class="text-muted" style="font-size:.75rem;">ASSIGNED TO</div>
                                                        <div>@(string.IsNullOrWhiteSpace(r.AssignedStaffName) ? "Not yet assigned" : r.AssignedStaffName)</div>
                                                        @if (!string.IsNullOrWhiteSpace(r.AssignmentNotes))
                                                        {
                                                            <div class="text-muted mt-1" style="font-size:.85rem;">Note: @r.AssignmentNotes</div>
                                                        }
                                                    </div>

                                                    <div>
                                                        <div class="text-muted mb-2" style="font-size:.75rem;">PHOTO FROM TENANT</div>
                                                        @if (!string.IsNullOrWhiteSpace(r.PhotoUrl))
                                                        {
                                                            <a href="#" target="_blank" rel="noopener" class="photo-link" data-photo-key="@r.PhotoUrl" style="display:none;">
                                                                <img alt="Issue reported at Unit @r.UnitNumber"
                                                                     class="img-fluid rounded border" style="max-height:340px;" />
                                                            </a>
                                                            <div class="text-muted mt-1 photo-loading" style="font-size:.75rem;">Loading photo&hellip;</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="text-muted">No photo was attached to this request.</div>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            <partial name="_Pagination" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Clicking a row opens its detail modal — but not when the click lands on
        // the Assign button or anything inside its own modal (which sits nested in
        // the row's markup). Relying on the row's own data-bs-toggle plus
        // event.stopPropagation() on the actions cell doesn't work: Bootstrap's
        // modal trigger listens on `document`, so stopping propagation there also
        // blocks the Assign button's own modal from opening. Handling it explicitly
        // here avoids that conflict.
        (function () {
            document.querySelectorAll('.maintenance-row').forEach(function (row) {
                row.addEventListener('click', function (e) {
                    if (e.target.closest('button, a, input, textarea, select, .modal')) return;

                    var target = document.querySelector(row.dataset.detailTarget);
                    if (target) bootstrap.Modal.getOrCreateInstance(target).show();
                });
            });
        })();

        // API Gateway endpoint fronting the Lambda that mints presigned S3 URLs.
        // The manager only ever views photos here, never uploads.
        var S3_ENDPOINT = '@(ViewBag.S3Endpoint ?? "")';

        (function () {
            if (!S3_ENDPOINT) return;

            document.querySelectorAll('.photo-link[data-photo-key]').forEach(function (link) {
                var loadingLabel = link.nextElementSibling;
                fetch(S3_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'getViewUrl', key: link.dataset.photoKey })
                })
                    .then(function (res) {
                        if (!res.ok) throw new Error('Request failed with status ' + res.status);
                        return res.json();
                    })
                    .then(function (data) {
                        if (!data.viewUrl) return;
                        link.href = data.viewUrl;
                        link.querySelector('img').src = data.viewUrl;
                        link.style.display = 'inline-block';
                        if (loadingLabel) loadingLabel.style.display = 'none';
                    })
                    .catch(function (err) {
                        console.error('Could not load photo', err);
                        if (loadingLabel) loadingLabel.textContent = 'Photo unavailable';
                    });
            });
        })();
    </script>
}