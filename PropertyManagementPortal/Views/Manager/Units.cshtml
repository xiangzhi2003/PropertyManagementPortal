@using PropertyManagementPortal.ViewModels.Manager
@model UnitListViewModel
@{ ViewData["Title"] = "Manage Units"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Manage Units</h4>
        <span class="text-muted small">Units across your assigned properties</span>
    </div>
    @if (Model.PropertyOptions.Any())
    {
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUnitModal">
            + Add Unit
        </button>
    }
</div>

@if (!Model.PropertyOptions.Any())
{
    <div class="alert alert-info">
        No property has been assigned to you yet, so there are no units to manage. Contact your administrator.
    </div>
}
else
{
    <!-- Filter bar -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" asp-action="Units" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small text-muted mb-1">Property</label>
                    <select name="propertyId" class="form-select form-select-sm" asp-items="Model.PropertyOptions">
                        <option value="">All properties</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Status</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">All statuses</option>
                        @foreach (var s in UnitFormViewModel.UnitStatuses)
                        {
                            <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Search unit no.</label>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="e.g. A-12" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-outline-primary flex-grow-1">Filter</button>
                    <a asp-action="Units" class="btn btn-sm btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Units table -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8fafc;">
                        <tr>
                            <th class="ps-3">Property</th>
                            <th>Unit No.</th>
                            <th>Type</th>
                            <th>Floor</th>
                            <th>Rent</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Units.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No units match your filters.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var u in Model.Units)
                            {
                                var (bg, fg) = u.Status == "Occupied"
                                    ? ("#dcfce7", "#16a34a")
                                    : ("#f3f4f6", "#6b7280");
                                <tr>
                                    <td class="ps-3 fw-semibold">@u.PropertyName</td>
                                    <td>@u.UnitNumber</td>
                                    <td>@u.Type</td>
                                    <td>@u.Floor</td>
                                    <td>RM @u.RentAmount.ToString("N2")</td>
                                    <td><span class="badge" style="background:@bg;color:@fg;">@u.Status</span></td>
                                    <td class="text-end pe-3">
                                        <a asp-action="EditUnit" asp-route-id="@u.UnitId" class="btn btn-sm btn-outline-primary">Edit</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Add Unit modal -->
    <div class="modal fade" id="addUnitModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="AddUnit">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Add Unit</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Property</label>
                            <select name="PropertyId" class="form-select" asp-items="Model.PropertyOptions" required>
                                <option value="">Select a property</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Unit Number</label>
                            <input type="text" name="UnitNumber" class="form-control" maxlength="20" required />
                        </div>
                        <div class="row g-2">
                            <div class="col-6 mb-3">
                                <label class="form-label">Type</label>
                                <select name="Type" class="form-select" required>
                                    <option value="">Select</option>
                                    @foreach (var t in UnitFormViewModel.UnitTypes)
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Status</label>
                                <select name="Status" class="form-select" required>
                                    @foreach (var s in UnitFormViewModel.UnitStatuses)
                                    {
                                        <option value="@s">@s</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-6 mb-3">
                                <label class="form-label">Rent Amount (RM)</label>
                                <input type="number" name="RentAmount" class="form-control" step="0.01" min="0.01" required />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Floor</label>
                                <input type="number" name="Floor" class="form-control" min="0" value="0" required />
                            </div>
                        </div>
                        <div class="mb-1">
                            <label class="form-label">Description <span class="text-muted small">(optional)</span></label>
                            <textarea name="Description" class="form-control" rows="2" maxlength="500"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Unit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
