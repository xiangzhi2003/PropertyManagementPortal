@using PropertyManagementPortal.ViewModels.Manager
@model ApplicationListViewModel
@{ ViewData["Title"] = "Applications"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Tenant Applications</h4>
        <span class="text-muted small">Review and decide on tenancy applications for your units</span>
    </div>
    @if (Model.PendingCount > 0)
    {
        <span class="badge bg-warning text-dark" style="font-size:.85rem;">@Model.PendingCount pending</span>
    }
</div>

<!-- Status filter -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Applications" class="d-flex align-items-center gap-2">
            <span class="small text-muted">Filter:</span>
            @{
                var statuses = new[] { ("", "All"), ("Pending", "Pending"), ("Approved", "Approved"), ("Rejected", "Rejected") };
            }
            @foreach (var (val, label) in statuses)
            {
                var active = (Model.StatusFilter ?? "") == val;
                <button type="submit" name="status" value="@val"
                        class="btn btn-sm @(active ? "btn-primary" : "btn-outline-secondary")">@label</button>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8fafc;">
                    <tr>
                        <th class="ps-3">Tenant</th>
                        <th>Property / Unit</th>
                        <th>Lease Period</th>
                        <th>Applied</th>
                        <th>Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Applications.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No applications found.</td></tr>
                    }
                    else
                    {
                        @foreach (var a in Model.Applications)
                        {
                            var (bg, fg) = a.Status switch
                            {
                                "Approved" => ("#dcfce7", "#16a34a"),
                                "Rejected" => ("#fee2e2", "#dc2626"),
                                _ => ("#fef3c7", "#d97706")
                            };
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-semibold">@a.TenantName</div>
                                    <div class="text-muted" style="font-size:.8rem;">@a.TenantEmail</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@a.PropertyName</div>
                                    <div class="text-muted" style="font-size:.8rem;">Unit @a.UnitNumber</div>
                                </td>
                                <td class="small">@a.StartDate.ToString("dd MMM yyyy") &ndash; @a.EndDate.ToString("dd MMM yyyy")</td>
                                <td class="small">@a.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge" style="background:@bg;color:@fg;">@a.Status</span>
                                    @if (a.Status == "Rejected" && !string.IsNullOrWhiteSpace(a.Notes))
                                    {
                                        <div class="text-muted" style="font-size:.75rem;max-width:220px;">@a.Notes</div>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (a.Status == "Pending")
                                    {
                                        <div class="d-flex gap-2 justify-content-end">
                                            <form method="post" asp-action="ApproveApplication" class="d-inline"
                                                onsubmit="return confirm('Approve this application? The unit will be marked occupied and other pending applications for it will be declined.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@a.TenancyId" />
                                                <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal" data-bs-target="#rejectModal-@a.TenancyId">Reject</button>
                                        </div>

                                        <!-- Reject modal -->
                                        <div class="modal fade" id="rejectModal-@a.TenancyId" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <form method="post" asp-action="RejectApplication">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@a.TenancyId" />
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Reject Application</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p class="small text-muted mb-2">
                                                                Rejecting <strong>@a.TenantName</strong>'s application for
                                                                <strong>@a.PropertyName</strong>, Unit @a.UnitNumber.
                                                            </p>
                                                            <label class="form-label">Reason <span class="text-muted small">(optional)</span></label>
                                                            <textarea name="reason" class="form-control" rows="3" maxlength="500"
                                                                    placeholder="e.g. Incomplete documents, unit no longer available..."></textarea>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-danger">Reject Application</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            <partial name="_Pagination" model="Model" />
        </div>
    </div>
</div>
